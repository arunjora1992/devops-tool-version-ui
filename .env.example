# Optional: GitHub personal access token (avoids 60 req/hr unauthenticated limit)
# Create at https://github.com/settings/tokens — no scopes needed (public repos only)
GITHUB_TOKEN=

# Port the dashboard is exposed on (default: 3000)
DASHBOARD_PORT=3000

# Cache TTL in seconds — how long before version data is re-fetched (default: 1 hour)
CACHE_TTL_SECONDS=3600

# Corporate proxy (optional — leave empty if not needed)
# HTTP_PROXY=http://proxy.corp.example.com:8080
# HTTPS_PROXY=http://proxy.corp.example.com:8080
